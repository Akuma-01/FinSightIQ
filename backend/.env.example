# Database
DATABASE_URL=postgresql://finsight:finsight@localhost:5432/finsightiq

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=7

# Embedding (Phase 2)
EMBEDDING_PROVIDER=ollama        # groq | huggingface | ollama
GROQ_API_KEY=
HUGGINGFACE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# LLM Models — never hardcode in service files, always read from env
GROQ_MODEL_HEAVY=llama-3.1-70b-versatile
GROQ_MODEL_MID=mixtral-8x7b-32768
GROQ_MODEL_FAST=llama-3.1-8b-instant

# RAG (Phase 2+)
RAG_SIMILARITY_THRESHOLD=0.55

# File storage — MVP uses local disk
UPLOAD_DIR=./uploads

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# App
PORT=4000
NODE_ENV=development
