{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts | pino-pretty",
    "dev:raw": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "ts-node -r dotenv/config src/db/migrate.ts",
    "seed:prompts": "ts-node -r dotenv/config src/db/seeds/prompt-templates.ts",
    "seed:edgar": "ts-node -r dotenv/config src/scripts/seed-edgar.ts",
    "seed:sebi": "ts-node -r dotenv/config src/scripts/seed-sebi.ts",
    "seed:rbi": "ts-node -r dotenv/config src/scripts/seed-rbi.ts",
    "test:phase3-acceptance": "node ../scripts/phase3-acceptance-smoke.js",
    "test": "npm run build && node --test test/*.test.js",
    "test:all": "npm test && npm run test:phase3-acceptance",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.6",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "eventsource-parser": "^3.1.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cheerio": "^0.22.35",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^5.8.4",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^6.0.3"
  }
}
